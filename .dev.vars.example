OPENAI_COMPAT_API_KEY=change-me

# Bootstrap with either a fresh access token or, preferably, a refresh token.
# Do not commit real tokens.
# COPILOT_ACCESS_TOKEN=ey...
COPILOT_REFRESH_TOKEN=0.A...

# Upstash Redis REST is the default shared token store.
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-rest-token
# COPILOT_REDIS_TOKEN_KEY=copilot_tokens
# COPILOT_REDIS_LOCK_KEY=copilot_tokens_lock
# COPILOT_REDIS_LOCK_TTL_MS=10000

# Token exchange settings observed in the captures.
# COPILOT_CLIENT_ID=c0ab8ce9-e9a0-42e7-b064-33d422df41f1
# COPILOT_TOKEN_TENANT=organizations
# COPILOT_TOKEN_RESOURCE=https://substrate.office.com/sydney
# COPILOT_TOKEN_SCOPE=https://substrate.office.com/sydney/.default openid profile offline_access
# COPILOT_TOKEN_REDIRECT_URI=brk-multihub://outlook.office.com

# Privacy: default requests use Copilot temporary chat by adding disableMemory=1.
COPILOT_DISABLE_MEMORY=true

# Optional. If omitted, oid/tid are decoded from the access token and session ids
# are generated per request.
# COPILOT_USER_ID=
# COPILOT_TENANT_ID=
# COPILOT_SESSION_ID=
# COPILOT_CONVERSATION_ID=
# DEFAULT_MODEL=copilot-5.5-fast-response
# COPILOT_LOCALE=zh-cn
# COPILOT_MARKET=en-us
# COPILOT_TIMEZONE=Asia/Shanghai
